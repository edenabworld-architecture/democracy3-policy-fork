name: Public Display Quality Gate

on:
  workflow_dispatch:
  push:
    paths:
      - "index.html"
      - "bills-index.json"
      - "bills.json"
      - "reports/**"
      - "scripts/validate_public_korean.py"
      - "scripts/validate_public_schema_compat.py"
  pull_request:
    paths:
      - "index.html"
      - "bills-index.json"
      - "bills.json"
      - "reports/**"
      - "scripts/validate_public_korean.py"
      - "scripts/validate_public_schema_compat.py"

permissions:
  contents: read

jobs:
  validate-public-display:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - name: Validate Korean, encoding and repeated risks
        run: python scripts/validate_public_korean.py
      - name: Validate UI and report schema compatibility
        run: python scripts/validate_public_schema_compat.py
      - name: Upload quality reports
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: public-display-quality-reports
          path: |
            public-quality-report.json
            public-schema-compatibility-report.json
          if-no-files-found: ignore
